# Brickfund web — environment template
# Copy to web/.env.local and fill values. Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=https://brick-fund.com
NODE_ENV=production
PORT=3001
PLATFORM_FEE_PERCENT=3
SESSION_SECRET=change-me-to-a-long-random-string

# PocketBase
NEXT_PUBLIC_PB_URL=https://api.brick-fund.com
PB_URL=http://127.0.0.1:8093
PB_ADMIN_EMAIL=admin@your-domain.com
PB_ADMIN_PASSWORD=use-a-strong-unique-password

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Documenso (e-sign)
DOCUMENSO_BASE_URL=http://localhost:3100
DOCUMENSO_API_TOKEN=
DOCUMENSO_WEBHOOK_SECRET=
DOCUMENSO_LOI_TEMPLATE_ID=
DOCUMENSO_APA_TEMPLATE_ID=
